# Vienna OS — Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# REQUIRED — Core
# ============================================
VIENNA_OPERATOR_NAME=vienna
VIENNA_OPERATOR_PASSWORD=change-me-in-production
VIENNA_SESSION_SECRET=generate-a-random-string-here
NODE_ENV=production

# ============================================
# OPTIONAL — AI Provider (for chat features)
# ============================================
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# OPTIONAL — Notifications
# ============================================

# Slack (approval requests + execution notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_APPROVAL_CHANNEL=C0123456789

# Email (Resend — approval requests + daily digest)
RESEND_API_KEY=re_...
VIENNA_NOTIFICATION_EMAIL=operators@yourcompany.com

# ============================================
# OPTIONAL — Integrations
# ============================================

# GitHub (governed deployments + PR status checks)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# ============================================
# OPTIONAL — Stripe (subscription billing)
# ============================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# OPTIONAL — CORS
# ============================================
CORS_ORIGIN=https://console.regulator.ai,https://regulator.ai,http://localhost:5174

# ============================================
# OPTIONAL — Logging
# ============================================
LOG_LEVEL=info  # debug | info | warn | error
