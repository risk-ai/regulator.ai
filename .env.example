# Product Shell Environment Configuration (Stage 6)
# 
# This file documents environment variables for the Next.js product shell.
# Copy to .env.local for local development, configure in Vercel for deployments.

# =============================================================================
# Database (Neon Postgres — regulator schema)
# =============================================================================
# Used by product shell for proposal/warrant/audit data.
# NOT used by Vienna Runtime (Runtime has separate DATABASE_URL).
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-purple-smoke-adpumuth-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require

# =============================================================================
# Authentication (Stage 6 - Workspace Auth)
# =============================================================================
# Workspace proxy routes require authentication.
# 
# Development mode (no token):
#   WORKSPACE_AUTH_TOKEN not set → All requests allowed (frictionless local dev)
# 
# Staging/Production mode (token required):
#   WORKSPACE_AUTH_TOKEN set → Requires Authorization: Bearer <token> header
# 
# Generate token:
#   openssl rand -base64 32
# 
# Future: Replace with NextAuth session-based auth.
WORKSPACE_AUTH_TOKEN=

# NextAuth Configuration (Optional - Not yet implemented)
# When NextAuth is added, these will replace WORKSPACE_AUTH_TOKEN
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Optional - For future NextAuth integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Vienna Runtime Connection (Stage 6 - Required)
# =============================================================================
# URL to Vienna Runtime service (separate HTTP service)
# 
# Local development:
#   VIENNA_RUNTIME_URL=http://localhost:3001
# 
# Preview deployment (Vercel preview + Fly.io preview):
#   VIENNA_RUNTIME_URL=https://vienna-runtime-preview.fly.dev
# 
# Production deployment:
#   VIENNA_RUNTIME_URL=https://vienna-runtime.fly.dev
#   (or custom domain: https://runtime.your-domain.com)
VIENNA_RUNTIME_URL=http://localhost:3001
