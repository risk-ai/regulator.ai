# Vienna OS Environment Configuration
# 
# QUICKSTART SETUP:
# 1. Copy this file: cp .env.example .env
# 2. Get Anthropic API key: https://console.anthropic.com/
# 3. Add your key to ANTHROPIC_API_KEY below
# 4. Run: npm run dev
#
# For Docker: Copy this to .env.local instead

# ============================================================================
# Server Configuration  
# ============================================================================

# Server host and port
HOST=0.0.0.0
PORT=3100

# Environment (development, production, staging)
NODE_ENV=development

# Base URL for the API (used for CORS, redirects, etc.)
API_BASE_URL=http://localhost:3100

# ============================================================================
# Database Configuration
# ============================================================================

# Primary database (PostgreSQL for production, SQLite for development)
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/vienna_os

# SQLite (default, good for development):
SQLITE_PATH=~/.openclaw/runtime/prod/state/state-graph.db

# Database pool settings (PostgreSQL only)
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================================================
# AI Provider API Keys (REQUIRED)
# ============================================================================

# Anthropic (Claude models - REQUIRED for Vienna OS governance)
# Get your key: https://console.anthropic.com/
# Example: ANTHROPIC_API_KEY=sk-ant-api03-abcd1234...
ANTHROPIC_API_KEY=

# OpenAI (GPT models - optional alternative)
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-abc123...

# Local Ollama (free alternative, run: ollama serve)
# Download: https://ollama.ai/
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Authentication & Security
# ============================================================================

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=dev-session-secret-change-in-production

# JWT secret (generate with: openssl rand -hex 32)  
JWT_SECRET=dev-jwt-secret-change-in-production

# Vienna session secret (generate with: openssl rand -hex 32)
VIENNA_SESSION_SECRET=dev-vienna-session-secret-change-in-production

# Vienna session TTL in seconds (default: 3600)
# VIENNA_SESSION_TTL=3600

# Warrant signing key (generate with: openssl rand -hex 32)
# Used for HMAC-SHA256 warrant signatures — change in production!
VIENNA_WARRANT_KEY=dev-warrant-key-change-in-production

# CORS allowed origins (comma-separated)
CORS_ORIGIN=https://console.regulator.ai,https://vienna-os.fly.dev,http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# Feature Flags
# ============================================================================

# Agent Intent Layer (Phase 28 - external agent integration)
ENABLE_AGENT_INTENT_LAYER=true

# Policy Engine (governance rules)
ENABLE_POLICY_ENGINE=true

# Warrant System (execution authorization)
ENABLE_WARRANT_SYSTEM=true

# Simulation Mode (dry-run execution)
ENABLE_SIMULATION=true

# Multi-tenant Mode
ENABLE_MULTI_TENANT=false

# ============================================================================
# Integrations
# ============================================================================

# Slack (for notifications, approvals, OAuth integration)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret

# GitHub (for PR status checks, audit trails)
# GITHUB_TOKEN=ghp_...
# GITHUB_ORG=your-org

# Email (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=vienna@your-domain.com

# ============================================================================
# Logging & Monitoring
# ============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Log format (json, pretty)
LOG_FORMAT=json

# Sentry (error tracking)
# SENTRY_DSN=https://...@sentry.io/...

# Datadog (APM, metrics)
# DD_API_KEY=
# DD_APP_KEY=

# ============================================================================
# Storage
# ============================================================================

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Static files (frontend)
CLIENT_DIST_PATH=./client/dist

# ============================================================================
# Stripe (billing & subscriptions)
# ============================================================================

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard → Products)
# STRIPE_PRICE_TEAM_MONTHLY=price_...
# STRIPE_PRICE_BUSINESS_MONTHLY=price_...
# STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ============================================================================
# PostgreSQL Database (Production)
# ============================================================================

# Neon or any PostgreSQL connection string
# POSTGRES_URL=postgresql://user:password@host:5432/dbname

# ============================================================================
# Redis (optional, for caching/rate limiting)
# ============================================================================

# REDIS_URL=redis://localhost:6379

# ============================================================================
# Resend (transactional email)
# ============================================================================

# RESEND_API_KEY=re_...

# ============================================================================
# Discord (feedback webhook)
# ============================================================================

# FEEDBACK_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# ============================================================================
# Vienna OS Specific
# ============================================================================

# Environment (prod, staging, dev, test)
VIENNA_ENV=prod

# System tenant ID (for admin operations)
SYSTEM_TENANT_ID=system

# Default quota limits
DEFAULT_QUOTA_LIMIT=100
DEFAULT_BUDGET_LIMIT=1000

# Trading protection (if using NBA/Kalshi integration)
# ENABLE_TRADING_PROTECTION=true
# AUTONOMOUS_WINDOW_START=09:00
# AUTONOMOUS_WINDOW_END=22:00

# ============================================================================
# Development Only
# ============================================================================

# Hot reload (development only)
# ENABLE_HOT_RELOAD=true

# Debug mode (verbose logging)
# DEBUG=vienna:*

# Disable authentication (development only - NEVER in production)
# DISABLE_AUTH=false
