{
  "version": 2,
  "regions": ["iad1"],
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/v1/health", "dest": "/api/v1/health" },
    { "src": "/api/v1/agents(.*)", "dest": "/api/v1/agents" },
    { "src": "/api/v1/policies(.*)", "dest": "/api/v1/policies" },
    { "src": "/api/v1/warrants(.*)", "dest": "/api/v1/warrants" },
    { "src": "/api/v1/api-keys(.*)", "dest": "/api/v1/api-keys" },
    { "src": "/api/v1/webhooks(.*)", "dest": "/api/v1/webhooks" },
    { "src": "/api/v1/approvals(.*)", "dest": "/api/v1/approvals" },
    { "src": "/api/v1/executions(.*)", "dest": "/api/v1/executions" },
    { "src": "/api/v1/execution-records(.*)", "dest": "/api/v1/execution-records" },
    { "src": "/api/v1/events(.*)", "dest": "/api/v1/events" },
    { "src": "/api/v1/audit(.*)", "dest": "/api/v1/audit" },
    { "src": "/api/v1/auth(.*)", "dest": "/api/v1/auth" },
    { "src": "/api/v1/rbac(.*)", "dest": "/api/v1/rbac" },
    { "src": "/api/v1/refresh(.*)", "dest": "/api/v1/refresh" },
    { "src": "/api/(.*)", "dest": "/api/server" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/((?!api|assets).*)", "dest": "/public/index.html" }
  ]
}
