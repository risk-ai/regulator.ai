# Vienna OS Console Server — Environment Variables
# Copy to .env and fill in values

# =============================================================================
# REQUIRED
# =============================================================================

# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=production

# Session secret (generate: openssl rand -hex 32)
SESSION_SECRET=change-me-to-random-hex-string

# JWT secret (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-random-hex-string

# CORS origins (comma-separated)
CORS_ORIGIN=https://console.regulator.ai,https://regulator.ai

# =============================================================================
# DATABASE (choose one)
# =============================================================================

# Option 1: Neon Postgres (recommended for production)
POSTGRES_URL=postgres://user:pass@host/dbname?sslmode=require

# Option 2: SQLite (for local development — no setup needed)
# Leave POSTGRES_URL empty to use SQLite at ~/.vienna/state-graph.db

# =============================================================================
# OPTIONAL — AI Provider (for chat/assistant features)
# =============================================================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (fallback)
OPENAI_API_KEY=sk-xxxxx

# Local Ollama (no key needed)
# OLLAMA_URL=http://localhost:11434

# =============================================================================
# OPTIONAL — External Integrations
# =============================================================================

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Email (Resend)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@regulator.ai

# GitHub (governed deployments)
GITHUB_TOKEN=ghp_xxxxx

# =============================================================================
# OPTIONAL — Warrant Signing
# =============================================================================

# HMAC key for warrant signatures (generate: openssl rand -hex 32)
VIENNA_WARRANT_KEY=change-me-for-production
