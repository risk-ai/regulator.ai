# Vienna Console Server - Postgres Environment Variables
# Copy to .env for local development

# Vercel Postgres (required)
# Get this from Vercel dashboard after creating Postgres database
POSTGRES_URL="postgres://username:password@host:5432/database"

# Or for local development with Docker:
# POSTGRES_URL="postgres://postgres:dev@localhost:5432/vienna_dev"

# Vienna Operator Authentication (required)
VIENNA_OPERATOR_PASSWORD="your-secure-password-here"

# Optional: Operator name (defaults to "vienna")
VIENNA_OPERATOR_NAME="vienna"

# Session Secret (required in production)
# Generate with: openssl rand -hex 32
VIENNA_SESSION_SECRET="your-session-secret-here"

# Optional: Session TTL in milliseconds (default: 86400000 = 24 hours)
VIENNA_SESSION_TTL="86400000"

# Optional: Environment (prod|test)
VIENNA_ENV="prod"

# Optional: Node environment
NODE_ENV="production"

# Optional: Server port
PORT="3100"

# Optional: Host binding
HOST="0.0.0.0"

# Optional: OpenClaw workspace path
OPENCLAW_WORKSPACE="/home/user/.openclaw/workspace"
