{
  "name": "@vienna/console-server",
  "version": "8.0.0",
  "description": "Vienna Console Server - Phase 8 Operator Control Surface",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json || tsc --skipLibCheck --noEmitOnError false",
    "build:prod": "node esbuild.config.mjs",
    "start": "node dist/server.js",
    "start:prod": "node build/server.cjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@vercel/postgres": "^0.5.1",
    "@vienna/lib": "file:../../../services/vienna-lib",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
