{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "outDir": "./dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowJs": true,
    "noImplicitAny": false,
    "baseUrl": "./src",
    "paths": {
      "@vienna-lib/*": ["../../../../services/vienna-lib/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../lib/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
