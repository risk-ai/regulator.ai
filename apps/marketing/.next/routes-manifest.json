      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/console",
      "destination": "https://console.regulator.ai",
      "statusCode": 307,
      "regex": "^(?!/_next)/console(?:/)?$"
    },
    {
      "source": "/console/:path*",
      "destination": "https://console.regulator.ai/:path*",
      "statusCode": 307,
      "regex": "^(?!/_next)/console(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
