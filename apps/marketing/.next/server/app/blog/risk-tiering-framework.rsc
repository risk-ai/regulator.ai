$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-shield w-6 h-6 text-violet-400","children":[["$","path","oel41y",{"d":"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"}],"$undefined"]}],["$","span",null,{"className":"text-sm","children":"Back to Blog"}]]}]}]}],["$","main",null,{"className":"max-w-3xl mx-auto px-6 py-12","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"text-xs font-medium px-2.5 py-1 rounded-full text-amber-400 bg-amber-500/10","children":"Framework"}],["$","div",null,{"className":"flex items-center gap-1 text-xs text-slate-500","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-3 h-3","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","polyline","68esgv",{"points":"12 6 12 12 16 14"}],"$undefined"]}],"7 min"]}],["$","span",null,{"className":"text-xs text-slate-600","children":"March 25, 2026"}]]}],["$","h1",null,{"className":"text-3xl font-bold text-white mb-8 leading-tight","children":"Designing a Risk Tiering Framework for AI Agent Actions"}],["$","article",null,{"className":"prose-vienna","children":[["$","br","0",{}],["$","h2","1",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"Not All Actions Are Equal"}],["$","br","2",{}],["$","p","3",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["A file read and a wire transfer are both \"agent actions.\" But treating them the same is either dangerously permissive or uselessly restrictive."]}],["$","br","4",{}],["$","p","5",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Risk tiering solves this by classifying every agent action into tiers that determine the governance process. Here's a practical framework."]}],["$","br","6",{}],["$","h2","7",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"The Three-Tier Model"}],["$","br","8",{}],["$","h3","9",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"T0 — Reversible / Low-Stakes"}],["$","p","10",{"className":"text-slate-400 italic text-sm mt-6","children":"*Auto-approved. No operator intervention.*"}],["$","br","11",{}],["$","p","12",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Examples:"]}],["$","li","13",{"className":"text-slate-300 ml-4 text-sm","children":"Reading a file or database"}],["$","li","14",{"className":"text-slate-300 ml-4 text-sm","children":"Checking service status"}],["$","li","15",{"className":"text-slate-300 ml-4 text-sm","children":"Internal logging or reasoning"}],["$","li","16",{"className":"text-slate-300 ml-4 text-sm","children":"Querying an API (GET requests)"}],["$","br","17",{}],["$","p","18",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Why auto-approve? These actions are read-only or easily reversible. Requiring approval would create bottlenecks without adding safety. The governance pipeline still records them in the audit trail."]}],["$","br","19",{}],["$","h3","20",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"T1 — Moderate Stakes"}],["$","p","21",{"className":"text-slate-400 italic text-sm mt-6","children":"*Requires operator approval. Single-party.*"}],["$","br","22",{}],["$","p","23",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Examples:"]}],["$","li","24",{"className":"text-slate-300 ml-4 text-sm","children":"Restarting a service"}],["$","li","25",{"className":"text-slate-300 ml-4 text-sm","children":"Updating configuration"}],["$","li","26",{"className":"text-slate-300 ml-4 text-sm","children":"Writing to a database"}],["$","li","27",{"className":"text-slate-300 ml-4 text-sm","children":"Sending an internal notification"}],["$","li","28",{"className":"text-slate-300 ml-4 text-sm","children":"Creating a support ticket"}],["$","br","29",{}],["$","p","30",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Why require approval? These actions have real-world effects that could cause disruption if wrong, but a single informed operator can assess the risk."]}],["$","br","31",{}],["$","h3","32",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"T2 — Irreversible / High-Impact"}],["$","p","33",{"className":"text-slate-400 italic text-sm mt-6","children":"*Requires multi-party approval. Time-limited warrants.*"}],["$","br","34",{}],["$","p","35",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Examples:"]}],["$","li","36",{"className":"text-slate-300 ml-4 text-sm","children":"Production deployments"}],["$","li","37",{"className":"text-slate-300 ml-4 text-sm","children":"Financial transactions"}],["$","li","38",{"className":"text-slate-300 ml-4 text-sm","children":"Deleting data"}],["$","li","39",{"className":"text-slate-300 ml-4 text-sm","children":"Sending external communications (emails, campaigns)"}],["$","li","40",{"className":"text-slate-300 ml-4 text-sm","children":"Legal filings"}],["$","li","41",{"className":"text-slate-300 ml-4 text-sm","children":"Infrastructure changes (scaling, region migration)"}],["$","br","42",{}],["$","p","43",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Why multi-party? The blast radius of errors is high and consequences may be irreversible. Multiple reviewers reduce single-point-of-failure in approval."]}],["$","br","44",{}],["$","h2","45",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"Implementing Risk Tiers"}],["$","br","46",{}],["$","h3","47",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"Step 1: Classify your agent actions"}],["$","p","48",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["List every action your agents can perform. For each one, ask:"]}],["$","li","49",{"className":"text-slate-300 ml-4 text-sm","children":"Is it read-only or does it change state?"}],["$","li","50",{"className":"text-slate-300 ml-4 text-sm","children":"Is it reversible?"}],["$","li","51",{"className":"text-slate-300 ml-4 text-sm","children":"What's the blast radius if it goes wrong?"}],["$","li","52",{"className":"text-slate-300 ml-4 text-sm","children":"Are there regulatory implications?"}],["$","br","53",{}],["$","h3","54",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"Step 2: Map actions to tiers"}],["$","p","55",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Use the answers above to assign each action to T0, T1, or T2. When in doubt, tier up — you can always relax later."]}],["$","br","56",{}],["$","h3","57",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"Step 3: Define approval workflows"}],["$","li","58",{"className":"text-slate-300 ml-4 text-sm","children":"T0: Auto-approve, log only"}],["$","li","59",{"className":"text-slate-300 ml-4 text-sm","children":"T1: Single operator approval, 15-minute warrant TTL"}],["$","li","60",{"className":"text-slate-300 ml-4 text-sm","children":"T2: Multi-party approval, 5-minute warrant TTL, mandatory rollback plan"}],["$","br","61",{}],["$","h3","62",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"Step 4: Monitor and iterate"}],["$","p","63",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Review your tier assignments quarterly. Actions that consistently auto-approve without issues can potentially move down a tier. Actions that cause incidents should move up."]}],["$","br","64",{}],["$","h2","65",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"Common Mistakes"}],["$","br","66",{}],["$","p","67",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["",["$","strong","1",{"className":"text-white font-semibold","children":"Over-tiering everything."}]," If every action requires approval, operators get alert fatigue and start rubber-stamping. Be disciplined about what's actually T1/T2."]}],["$","br","68",{}],["$","p","69",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["",["$","strong","1",{"className":"text-white font-semibold","children":"Under-tiering financial actions."}]," Money movements should always be T2, regardless of amount. The reputational risk of an unauthorized transfer outweighs the friction cost."]}],["$","br","70",{}],["$","p","71",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["",["$","strong","1",{"className":"text-white font-semibold","children":"Ignoring the compound effect."}]," A single T0 action might be safe, but 1,000 T0 actions in rapid succession could be an attack. Consider rate limiting and anomaly detection alongside tiering."]}],["$","br","72",{}],["$","h2","73",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"In Vienna OS"}],["$","br","74",{}],["$","p","75",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Vienna OS implements this framework natively. The Policy Engine assigns risk tiers based on configurable rules. The Intent Gateway routes actions through the appropriate approval workflow. And the Verification Engine confirms execution stayed within the warranted scope."]}],["$","br","76",{}],["$","hr","77",{"className":"border-navy-700 my-8"}],["$","br","78",{}],["$","p","79",{"className":"text-slate-400 italic text-sm mt-6","children":"Set up your risk tiers in under 5 minutes. Read the docs →"}],["$","br","80",{}]]}],["$","$Lf",null,{"slug":"risk-tiering-framework"}],["$","div",null,{"className":"mt-12","children":["$","$L10",null,{"variant":"compact","showSocialProof":true,"className":"max-w-lg mx-auto"}]}]]}],["$","footer",null,{"className":"border-t border-navy-700 py-8 mt-12","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6 text-center","children":[["$","a",null,{"href":"/blog","className":"inline-flex items-center gap-2 text-slate-400 hover:text-white transition mb-4","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Back to Blog"]}],["$","div",null,{"className":"text-xs text-slate-600","children":"© 2026 Technetwork 2 LLC dba ai.ventures. All rights reserved."}]]}]}]]}]
