nt(intent.status)      # 'approved' | 'pending' | 'denied'\nprint(intent.risk_tier)   # 'T0' | 'T1' | 'T2' | 'T3'\nprint(intent.warrant.id)  # warrant ID if approved"}]}]]}]]}]]}]]}],["$","div","4",{"className":"relative","children":[["$","div",null,{"className":"flex items-center gap-4 mb-6","children":[["$","div",null,{"className":"flex items-center justify-center w-10 h-10 rounded-full bg-violet-600 text-white font-bold text-lg","children":4}],["$","h2",null,{"className":"text-2xl font-bold","children":"Execute with the Warrant"}]]}],["$","div",null,{"className":"ml-14 space-y-4","children":[["$","p","0",{"className":"text-slate-300","children":"If the intent is approved, you receive a cryptographic warrant. Use it to execute the action through Vienna OS's controlled execution path."}],["$","div","1",{"className":"space-y-2","children":[["$","div","0",{"children":[["$","p",null,{"className":"text-xs text-slate-500 mb-1 font-medium","children":"TypeScript"}],["$","pre",null,{"className":"bg-slate-900 border border-slate-800 rounded-lg p-4 overflow-x-auto","children":["$","code",null,{"className":"text-sm text-slate-200 font-mono","children":"// Execute using the warrant\nif (intent.status === 'approved') {\n  const result = await vienna.execute(intent.warrant.id, {\n    // Your actual execution logic\n    action: () => deployService('api-service', '2.4.1')\n  });\n\n  console.log(result.verified);   // true — post-execution verification passed\n  console.log(result.auditId);    // immutable audit trail entry ID\n}"}]}]]}],["$","div","1",{"children":[["$","p",null,{"className":"text-xs text-slate-500 mb-1 font-medium","children":"Python"}],["$","pre",null,{"className":"bg-slate-900 border border-slate-800 rounded-lg p-4 overflow-x-auto","children":["$","code",null,{"className":"text-sm text-slate-200 font-mono","children":"# Execute using the warrant\nif intent.status == \"approved\":\n    result = vienna.execute(\n        warrant_id=intent.warrant.id,\n        act