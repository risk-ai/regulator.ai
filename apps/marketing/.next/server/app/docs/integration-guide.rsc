s: ['deploy_code', 'send_email', 'query_database']\n});"}]}]]}],["$","div",null,{"className":"bg-[#111826] rounded-lg p-6 border border-gray-800","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"w-8 h-8 rounded-full bg-purple-600 flex items-center justify-center text-sm font-bold","children":3}],["$","h3",null,{"className":"text-lg font-semibold","children":"Submit intents before acting"}]]}],["$","pre",null,{"className":"bg-[#0B0F19] rounded p-4 overflow-x-auto text-sm text-gray-300 font-mono","children":["$","code",null,{"children":"// Before executing any action, submit intent to Vienna\nconst result = await vienna.submitIntent({\n  action: 'deploy_code',\n  params: { service: 'api-gateway', version: '2.3.1' },\n  objective: 'Deploy API v2.3.1 to production'\n});\n\nif (result.status === 'approved') {\n  // Execute with warrant\n  await deployService('api-gateway', '2.3.1');\n  \n  // Report execution result\n  await vienna.reportExecution(result.warrant_id, {\n    success: true,\n    output: 'Deployed api-gateway v2.3.1'\n  });\n} else if (result.status === 'pending') {\n  // T2/T3 — wait for human approval\n  const approved = await vienna.waitForApproval(result.intent_id);\n  if (approved.status === 'approved') {\n    await deployService('api-gateway', '2.3.1');\n    await vienna.reportExecution(approved.warrant_id, { success: true });\n  }\n}"}]}]]}]]}]]}],["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-semibold mb-6 text-purple-400","children":"Framework Examples"}],["$","div",null,{"className":"space-y-8","children":[["$","div",null,{"className":"bg-[#111826] rounded-lg p-6 border border-gray-800","children":[["$","h3",null,{"className":"text-lg font-semibold mb-1","children":"LangChain / LangGraph"}],["$","p",null,{"className":"text-gray-400 text-sm mb-4","children":"Wrap tool calls with Vienna governance"}],["$","pre",null,{"className":"bg-[#0B0F19] rounded p-4 overflow-x-auto text-sm text-gray-300 font-mono","children":["$","code",null,{"children":"import { createLangChainAdapter } from '@vienna/sdk';\n\nconst vienna = createLangChainAdapter({\n  apiUrl: 'https://api.regulator.ai',\n  apiKey: process.env.VIENNA_API_KEY,\n  agentId: 'langchain-agent-01'\n});\n\n// Create a governed tool\nfunction governedTool(toolFn, action) {\n  return async (...args) => {\n    const result = await vienna.submitIntent({\n      action,\n      params: { args },\n      objective: `Execute ${action}`\n    });\n    \n    if (result.status !== 'approved') {\n      throw new Error(`Action ${action} requires approval`);\n    }\n    \n    const output = await toolFn(...args);\n    await vienna.reportExecution(result.warrant_id, { \n      success: true, output: JSON.stringify(output) \n    });\n    return output;\n  };\n}"}]}]]}],["$","div",null,{"className":"bg-[#111826] rounded-lg p-6 border border-gray-800","children":[["$","h3",null,{"className":"text-lg font-semibold mb-1","children":"CrewAI"}],["$","p",null,{"className":"text-gray-400 text-sm mb-4","children":"Add governance to crew task execution"}],["$","pre",null,{"className":"bg-[#0B0F19] rounded p-4 overflow-x-auto text-sm text-gray-300 font-mono","children":["$","code",null,{"children":"from vienna import create_crewai_adapter\n\nvienna = create_crewai_adapter(\n    api_url=\"https://api.regulator.ai\",\n    api_key=os.environ[\"VIENNA_API_KEY\"],\n    agent_id=\"crewai-research-crew\"\n)\n\n# Before each task execution\nresult = vienna.submit_intent(\n    action=\"web_search\",\n    params={\"query\": \"AI governance market analysis\"},\n    objective=\"Research AI governance market for quarterly report\"\n)\n\nif result[\"status\"] == \"approved\":\n    # Proceed with crew task\n    crew.kickoff()\n    vienna.report_execution(result[\"warrant_id\"], success=True)"}]}]]}],["$","div",null,{"className":"bg-[#111826] rounded-lg p-6 border border-gray-800","children":[["$