:[["$","span","0",{"className":"text-xs bg-slate-800 border border-slate-700/50 rounded-full px-3 py-1 text-slate-400","children":"Cryptographic Warrant"}],["$","span","1",{"className":"text-xs bg-slate-800 border border-slate-700/50 rounded-full px-3 py-1 text-slate-400","children":"Warrant Scope"}],["$","span","2",{"className":"text-xs bg-slate-800 border border-slate-700/50 rounded-full px-3 py-1 text-slate-400","children":"Warrant TTL"}]]}],["$","$L5",null,{"href":"/blog/how-execution-warrants-work","className":"inline-flex items-center text-sm text-violet-400 hover:underline mt-3","children":"Learn more →"}]]}],["$","div","1",{"id":"risk-tiering","className":"bg-slate-900/50 border border-slate-800/50 rounded-xl p-6 scroll-mt-24","children":[["$","h2",null,{"className":"text-xl font-bold text-white mb-3","children":"Risk Tiering"}],["$","p",null,{"className":"text-slate-300 leading-relaxed mb-4","children":"A classification system that assigns every agent action a risk level from T0 (minimal risk, auto-approved) to T3 (critical risk, requires multi-party human approval with justification and rollback plan). Risk tiers determine the approval workflow required before execution."}],["$","div",null,{"className":"flex flex-wrap gap-2","children":[["$","span","0",{"className":"text-xs bg-slate-800 border border-slate-700/50 rounded-full px-3 py-1 text-slate-400","children":"T0"}],["$","span","1",{"className":"text-xs bg-slate-800 border border-slate-700/50 rounded-full px-3 py-1 text-slate-400","children":"T1"}],["$","span","2",{"className":"text-xs bg-slate-800 border border-slate-700/50 rounded-full px-3 py-1 text-slate-400","children":"T2"}],["$","span","3",{"className":"text-xs bg-slate-800 border border-slate-700/50 rounded-full px-3 py-1 text-slate-400","children":"T3"}],["$","span","4",{"className":"text-xs bg-slate-800 border border-slate-700/50 rounded-full px-3 py-1 text-slate-400","children":"Risk Assessment"}]]}],["$","$L5",null,{"href":"/blog/risk-tierin