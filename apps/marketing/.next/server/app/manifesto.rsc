7:["$","$1","c",{"children":[["$","main",null,{"className":"min-h-screen bg-gradient-to-b from-slate-950 via-navy-950 to-slate-950 text-white","children":[["$","div",null,{"className":"max-w-3xl mx-auto px-6 pt-24 pb-12","children":[["$","$Le",null,{"href":"/","className":"inline-flex items-center text-sm text-slate-400 hover:text-white mb-12 transition","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-shield w-4 h-4 mr-2","children":[["$","path","oel41y",{"d":"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"}],"$undefined"]}]," Back to Home"]}],["$","h1",null,{"className":"text-4xl md:text-5xl font-bold mb-6 leading-tight","children":"The Vienna Manifesto"}],["$","p",null,{"className":"text-xl text-slate-300 italic mb-2","children":"Principles for governed AI execution"}],["$","div",null,{"className":"w-16 h-1 bg-gradient-to-r from-violet-500 to-cyan-400 rounded-full mb-12"}],["$","div",null,{"className":"prose prose-lg prose-invert max-w-none mb-12","children":[["$","p",null,{"className":"text-slate-300 leading-relaxed text-lg","children":"We are building a world where AI agents act autonomously on behalf of humans and organizations. They will deploy code, move money, manage infrastructure, make business decisions, and interact with the physical world. This is not a future scenario — it is happening now."}],["$","p",null,{"className":"text-slate-300 leading-relaxed text-lg mt-4","children":"The question is not whether AI agents will be autonomous. The question is whether that autonomy will be governed. These are our beliefs about what governed means."}]]}]]}],["$","div",null,{"className":"max-w-3xl mx-auto px-6 pb-24","children":[["$","div",null,{"className":"space-y-12","children":[["$","div","0",{"className":"border-l-2 border-violet-500/30 pl-8","children":[["$","div",null,{"className":"text-sm text-violet-400 font-medium mb-2","children":["Principle ","I"]}],["$","h2",null,{"className":"text-2xl font-bold mb-4","children":"No execution without authorization"}],["$","p",null,{"className":"text-slate-300 leading-relaxed","children":"Every autonomous action must be explicitly authorized before it happens. The default for any AI agent should be denial, not permission. This isn't a limitation — it's the foundation of trust between humans and machines."}]]}],["$","div","1",{"className":"border-l-2 border-violet-500/30 pl-8","children":[["$","div",null,{"className":"text-sm text-violet-400 font-medium mb-2","children":["Principle ","II"]}],["$","h2",null,{"className":"text-2xl font-bold mb-4","children":"Authorization must be cryptographic, not cosmetic"}],["$","p",null,{"className":"text-slate-300 leading-relaxed","children":"A log entry is not authorization. A permissions matrix is not authorization. True authorization means a verifiable, tamper-evident, time-limited token that binds intent to approval to execution. If you can't prove it mathematically, you can't prove it."}]]}],["$","div","2",{"className":"border-l-2 border-violet-500/30 pl-8","children":[["$","div",null,{"className":"text-sm text-violet-400 font-medium mb-2","children":["Principle ","III"]}],["$","h2",null,{"className":"text-2xl font-bold mb-4","children":"Risk must be classified, not assumed"}],["$","p",null,{"className":"text-slate-300 leading-relaxed","children":"Not all actions are equal. A health check and a wire transfer have fundamentally different risk profiles and deserve fundamentally different governance. Systems that treat all actions identically are either too restrictive to be useful or too permissive to be safe."}]]}],"$Lf","$L10","$L11","$L12"]}],"$L13"]}]]}],["$L14"],"$L15"]}]
