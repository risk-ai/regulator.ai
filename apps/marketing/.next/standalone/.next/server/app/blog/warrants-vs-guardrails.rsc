xt-white font-semibold","children":"after"}]," people have already entered the vault and taken the money? Of course not. You'd require authorization ",["$","strong","3",{"className":"text-white font-semibold","children":"before"}]," they can enter."]}],["$","br","4",{}],["$","p","5",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Yet this is exactly how most AI safety systems work today. They operate reactively—filtering outputs after AI models have already made decisions, rather than governing actions before they're executed."]}],["$","br","6",{}],["$","h2","7",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"Guardrails: The Current Approach"}],["$","br","8",{}],["$","p","9",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Most AI safety implementations today follow the guardrails model:"]}],["$","br","10",{}],["$","div","11",{"className":"bg-navy-800 border border-navy-700 rounded-lg p-4 my-4 font-mono text-sm text-slate-300 overflow-x-auto","children":""}],["$","p","12",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["AI Model → Output Generation → Safety Filter → Approved Output"]}],["$","div","13",{"className":"bg-navy-800 border border-navy-700 rounded-lg p-4 my-4 font-mono text-sm text-slate-300 overflow-x-auto","children":""}],["$","br","14",{}],["$","p","15",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["This works well for content-focused applications, but has critical weaknesses when applied to autonomous agents:"]}],["$","br","16",{}],["$","h3","17",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"Timing Problems"}],["$","p","18",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Guardrails operate ",["$","strong","1",{"className":"text-white font-semibold","children":"after"}]," the AI has already decided what to do. For autonomous agents, this is often too late."]}],["$","br","19",{}],["$","h3","20",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"Execution vs. Content"}],["$","p","21",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Guardrails filter what AI systems can say. But autonomous agents need governance over what they can ",["$","strong","1",{"className":"text-white font-semibold","children":"do"}],"."]}],["$","br","22",{}],["$","h2","23",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"Execution Warrants: A Proactive Model"}],["$","br","24",{}],["$","p","25",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Instead of filtering outputs, execution warrants govern actions at the intent level:"]}],["$","br","26",{}],["$","div","27",{"className":"bg-navy-800 border border-navy-700 rounded-lg p-4 my-4 font-mono text-sm text-slate-300 overflow-x-auto","children":""}],["$","p","28",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Agent Intent → Risk Assessment → Approval → Signed Warrant → Execution"]}],["$","div","29",{"className":"bg-navy-800 border border-navy-700 rounded-lg p-4 my-4 font-mono text-sm text-slate-300 overflow-x-auto","children":""}],["$","br","30",{}],["$","p","31",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Every approved action receives a cryptographically signed warrant with:"]}],["$","li","32",{"className":"text-slate-300 ml-4 text-sm","children":"**Scope**: Exactly what the agent is authorized to do"}],["$","li","33",{"className":"text-slate-300 ml-4 text-sm","children":"**Time limits**: When the warrant expires"}],["$","li","34",{"className":"text-slate-300 ml-4 text-sm","children":"**Constraints**: Parameter bounds the execution must respect"}],["$","li","35",{"className":"text-slate-300 ml-4 text-sm","children":"**Audit trail**: Complete record of approval chain"}],["$","br","36",{}],["$","h2","37",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"Real-World Example"}],["$","br","38",{}],["$","p","39",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["",["$","strong","1",{"className":"text-white font-semibold","children":"Scenario"}],": AI agent wants to scale database cluster"]}],["$","br","40",{}],["$","p","41",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["",["$","strong","1",{"className":"text-white font-semibold","children":"Guardrails approach"}],":"]}],["$","li","42",{"className":"text-slate-300 ml-4 text-sm","children":"Agent executes scaling"}],["$","li","43",{"className":"text-slate-300 ml-4 text-sm","children":"System monitors outputs"}],["$","li","44",{"className":"text-slate-300 ml-4 text-sm","children":"Too late to prevent $20K/month cost impact"}],["$","br","45",{}],["$","p","46",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["",["$","strong","1",{"className":"text-white font-semibold","children":"Warrant approach"}],":"]}],["$","li","47",{"className":"text-slate-300 ml-4 text-sm","children":"Agent submits scaling intent"}],["$","li","48",{"className":"text-slate-300 ml-4 text-sm","children":"System evaluates cost impact ($20K/month)"}],["$","li","49",{"className":"text-slate-300 ml-4 text-sm","children":"Routes to DevOps team for approval"}],["$","li","50",{"className":"text-slate-300 ml-4 text-sm","children":"Team reviews and denies (temporary traffic spike)"}],["$","li","51",{"className":"text-slate-300 ml-4 text-sm","children":"No scaling, no unnecessary cost"}],["$","br","52",{}],["$","h2","53",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"Why Warrants Work"}],["$","br","54",{}],["$","p","55",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["1. ",["$","strong","1",{"className":"text-white font-semibold","children":"Proactive control"}],": Stop problems before they happen"]}],["$","p","56",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["2. ",["$","strong","1",{"className":"text-white font-semibold","children":"Risk-aware"}],": Different approval flows for different risk levels"]}],["$","p","57",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["3. ",["$","strong","1",{"className":"text-white font-semibold","children":"Cryptographically verifiable"}],": Tamper-evident audit trails"]}],["$","p","58",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["4. ",["$","strong","1",{"className":"text-white font-semibold","children":"Time-limited"}],": Warrants expire, preventing stale authorizations"]}],["$","p","59",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["5. ",["$","strong","1",{"className":"text-white font-semibold","children":"Scope-constrained"}],": Agents can only do exactly what's approved"]}],["$","br","60",{}],["$","hr","61",{"className":"border-navy-700 my-8"}],["$","br","62",{}],["$","p","63",{"className":"text-slate-400 italic text-sm mt-6","children":"Learn how to implement execution warrants in your systems. Read the docs →"}],["$","br","64",{}]]}],["$","$Lf",null,{"slug":"warrants-vs-guardrails"}],["$","div",null,{"className":"mt-12","children":["$","$L10",null,{"variant":"compact","showSocialProof":true,"className":"max-w-lg mx-auto"}]}]]}],["$","footer",null,{"className":"border-t border-navy-700 py-8 mt-12","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6 text-center","children":[["$","a",null,{"href":"/blog","className":"inline-flex items-center gap-2 text-slate-400 hover:text-white transition mb-4","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Back to Blog"]}],["$","div",null,{"className":"text-xs text-slate-600","c