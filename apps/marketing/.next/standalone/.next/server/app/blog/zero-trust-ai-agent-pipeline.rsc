efined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-shield w-6 h-6 text-violet-400","children":[["$","path","oel41y",{"d":"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"}],"$undefined"]}],["$","span",null,{"className":"text-sm","children":"Back to Blog"}]]}]}]}],["$","main",null,{"className":"max-w-3xl mx-auto px-6 py-12","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"text-xs font-medium px-2.5 py-1 rounded-full text-blue-400 bg-blue-500/10","children":"Security"}],["$","div",null,{"className":"flex items-center gap-1 text-xs text-slate-500","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-3 h-3","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","polyline","68esgv",{"points":"12 6 12 12 16 14"}],"$undefined"]}],"8 min"]}],["$","span",null,{"className":"text-xs text-slate-600","children":"March 28, 2026"}]]}],["$","h1",null,{"className":"text-3xl font-bold text-white mb-8 leading-tight","children":"Building a Zero-Trust AI Agent Pipeline"}],["$","article",null,{"className":"prose-vienna","children":[["$","p","0",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["# Building a Zero-Trust AI Agent Pipeline"]}],["$","br","1",{}],["$","p","2",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Traditional network security operates on the principle of \"trust but verify\" — establish a secure perimeter, and everything inside is trusted. But AI agents break this model entirely. They operate across cloud boundaries, interact with dozens of services, and make decisions that can impact your entire business. When an AI agent has the power to deploy code, manage infrastructure, or process customer data, \"trust but verify\" becomes \"trust and pray.\""]}],["$","br","3",{}],["$","p","4",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["",["$","strong","1",{"className":"text-white font-semibold","children":"The solution: Zero-trust architecture for AI agents."}]," Never trust, always verify, every action, every time."]}],["$","br","5",{}],["$","h2","6",{"className":"text-xl font-bold text-white mt-10 mb-4","children":"Why Zero-Trust Applies to AI Agents"}],["$","br","7",{}],["$","h3","8",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"The Traditional Security Perimeter is Dead"}],["$","br","9",{}],["$","p","10",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["In the pre-agent era, your security perimeter was your network boundary. Deploy a firewall, configure VPNs, and monitor ingress/egress traffic. But AI agents operate fundamentally differently:"]}],["$","br","11",{}],["$","li","12",{"className":"text-slate-300 ml-4 text-sm","children":"**Cross-boundary execution**: Agents call APIs across multiple clouds, services, and domains"}],["$","li","13",{"className":"text-slate-300 ml-4 text-sm","children":"**Dynamic privilege escalation**: An agent might need database access one minute, S3 permissions the next"}],["$","li","14",{"className":"text-slate-300 ml-4 text-sm","children":"**Autonomous decision-making**: No human in the loop means no human to catch mistakes"}],["$","li","15",{"className":"text-slate-300 ml-4 text-sm","children":"**Lateral movement potential**: A compromised agent can access everything in its permission set"}],["$","br","16",{}],["$","p","17",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Consider this scenario: Your customer service agent has Stripe API access to process refunds. Traditional security gives it a Stripe API key and trusts it to use it responsibly. But what if the agent gets confused and processes 1,000 refunds instead of 1? What if a prompt injection attack tricks it into refunding all transactions from last month?"]}],["$","br","18",{}],["$","p","19",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["",["$","strong","1",{"className":"text-white font-semibold","children":"Zero-trust principles solve this"}],": Instead of trusting the agent with permanent Stripe access, Vienna OS issues time-bound warrants for specific operations. Want to refund order #12345? Get a warrant for that specific order. Want to refund 50 orders? That requires additional approval and stronger constraints."]}],["$","br","20",{}],["$","h3","21",{"className":"text-lg font-semibold text-white mt-8 mb-3","children":"The Four Pillars of Zero-Trust for AI Agents"}],["$","br","22",{}],["$","p","23",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["#### 1. ",["$","strong","1",{"className":"text-white font-semibold","children":"Intent-Based Authorization"}],""]}],["$","p","24",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Instead of role-based permissions (\"this agent can access Stripe\"), Vienna OS uses intent-based authorization (\"this agent wants to refund order #12345\"). Every action starts with a declared intent:"]}],["$","br","25",{}],["$","p","26",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["<pre class=\"code-block\"><code>"]}],["$","p","27",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["// Traditional approach - dangerous"]}],["$","p","28",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["const stripe = new Stripe(process.env.STRIPE_SECRET_KEY);"]}],["$","p","29",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["await stripe.refunds.create({ payment_intent: \"pi_12345\" });"]}],["$","br","30",{}],["$","p","31",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["// Zero-trust approach - governed"]}],["$","p","32",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["const intent = await vienna.submitIntent({"]}],["$","p","33",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["action: \"stripe.refund.create\","]}],["$","p","34",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["target: \"pi_12345\","]}],["$","p","35",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["amount: 2500,"]}],["$","p","36",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["reason: \"customer_complaint\","]}],["$","p","37",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["agent_id: \"customer-service-001\""]}],["$","p","38",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["});"]}],["$","p","39",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["</code></pre>"]}],["$","br","40",{}],["$","p","41",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["#### 2. ",["$","strong","1",{"className":"text-white font-semibold","children":"Policy-Driven Constraints"}],""]}],["$","p","42",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Every intent gets evaluated against a policy framework that checks business rules, compliance requirements, and risk thresholds:"]}],["$","br","43",{}],["$","p","44",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["<pre class=\"code-block\"><code>"]}],["$","p","45",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["# Refund policy example"]}],["$","p","46",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["policies:"]}],["$","li","47",{"className":"text-slate-300 ml-4 text-sm","children":"name: \"refund-amount-limit\""}],["$","p","48",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["condition: \"intent.amount <= 5000\" # $50 max refund"]}],["$","p","49",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["action: \"allow\""]}],["$","br","50",{}],["$","li","51",{"className":"text-slate-300 ml-4 text-sm","children":"name: \"bulk-refund-protection\""}],["$","p","52",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["condition: \"count(agent.refunds, last_hour) > 5\""]}],["$","p","53",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["action: \"require_human_approval\""]}],["$","br","54",{}],["$","li","55",{"className":"text-slate-300 ml-4 text-sm","children":"name: \"suspicious-pattern\""}],["$","p","56",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["condition: \"intent.reason == 'test' OR intent.amount > order.amount\""]}],["$","p","57",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["action: \"deny\""]}],["$","p","58",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["</code></pre>"]}],["$","br","59",{}],["$","p","60",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["#### 3. ",["$","strong","1",{"className":"text-white font-semibold","children":"Cryptographic Warrants"}],""]}],["$","p","61",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["Approved intents receive time-bound, cryptographically signed warrants that prove authorization. No warrant, no execution:"]}],["$","br","62",{}],["$","p","63",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["<pre class=\"code-block\"><code>"]}],["$","p","64",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["// Warrant structure"]}],["$","p","65",{"className":"text-slate-300 text-sm leading-relaxed my-2","children":["{"]}],["$","p","66",{"className":"text-slate-300 text-sm leading-relaxe