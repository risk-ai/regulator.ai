# Vienna OS DevOps Agent Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# Vienna OS Configuration (Required)
# ============================================================================

# Vienna OS API endpoint
VIENNA_API_URL=http://localhost:3100

# API Key (for local development, use dev key)
VIENNA_API_KEY=dev_key_no_auth_needed

# For production, get your API key from Vienna OS console:
# VIENNA_API_KEY=vos_your_production_key_here

# ============================================================================
# Agent Configuration
# ============================================================================

# Operator identity (used in audit trails)
USER=devops-operator

# Environment designation
NODE_ENV=development

# Agent behavior settings
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000
OPERATION_TIMEOUT_MS=30000

# ============================================================================
# Debugging & Logging
# ============================================================================

# Enable debug logs
# DEBUG=vienna:*

# Log level (error, warn, info, debug)
LOG_LEVEL=info