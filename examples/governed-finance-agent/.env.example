# Vienna OS Finance Agent Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# Vienna OS Configuration (Required)
# ============================================================================

# Vienna OS API endpoint
VIENNA_API_URL=http://localhost:3100

# API Key (for local development, use dev key)
VIENNA_API_KEY=dev_key_no_auth_needed

# For production, get your API key from Vienna OS console:
# VIENNA_API_KEY=vos_your_production_key_here

# ============================================================================
# Financial Agent Configuration
# ============================================================================

# Operator identity (used in audit trails and compliance)
OPERATOR_ID=finance-operator
OPERATOR_EMAIL=finance@company.com

# Trading configuration
TRADING_ACCOUNT_ID=demo-trading-account
MAX_POSITION_SIZE=100000
MAX_DAILY_LOSS=50000

# Wire transfer limits
MAX_DOMESTIC_TRANSFER=100000
MAX_INTERNATIONAL_TRANSFER=25000
REQUIRE_DUAL_APPROVAL_ABOVE=10000

# ============================================================================
# Compliance Configuration
# ============================================================================

# FINRA compliance settings
FINRA_FIRM_ID=12345
FINRA_ENABLE_POSITION_MONITORING=true

# BSA/AML settings
BSA_ENABLE_CTR_FILING=true
BSA_CTR_THRESHOLD=10000
AML_RISK_SCORING_ENABLED=true

# OFAC sanctions screening
OFAC_ENABLE_SCREENING=true
OFAC_API_KEY=your_ofac_api_key_here

# ============================================================================
# Debugging & Logging
# ============================================================================

# Environment
ENVIRONMENT=development

# Python logging level
LOG_LEVEL=INFO

# Enable debug mode
DEBUG=false

# Audit log retention (days)
AUDIT_RETENTION_DAYS=2555  # 7 years for SOX compliance