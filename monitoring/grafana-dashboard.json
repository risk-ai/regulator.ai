{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for Vienna OS metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Intent Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(vienna_intents_submitted_total[5m])",
          "legendFormat": "Submitted ({{risk_tier}})",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "rate(vienna_intents_approved_total[5m])",
          "legendFormat": "Approved ({{risk_tier}})",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "rate(vienna_intents_denied_total[5m])",
          "legendFormat": "Denied ({{risk_tier}})",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "Approvals Pending",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "vienna_approvals_pending",
          "legendFormat": "Pending",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "vienna_agents_active",
          "legendFormat": "Active",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "title": "Warrants Issued",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(increase(vienna_warrants_issued_total[24h]))",
          "legendFormat": "Last 24h",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "title": "Anomalies Detected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "targets": [
        {
          "expr": "sum(increase(vienna_anomalies_detected_total[24h]))",
          "legendFormat": "Last 24h",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Intent Processing Latency (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vienna_intent_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vienna_intent_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "histogram_quantile(0.99, rate(vienna_intent_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Approval Latency (p50, p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vienna_approval_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vienna_approval_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Policy Evaluations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(vienna_policy_evaluations_total{result=\"allow\"}[5m])",
          "legendFormat": "Allow",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "rate(vienna_policy_evaluations_total{result=\"deny\"}[5m])",
          "legendFormat": "Deny",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(vienna_http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(vienna_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(vienna_errors_total[5m])",
          "legendFormat": "{{type}}",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vienna-os", "governance", "ai-agents"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Vienna OS — Governance Dashboard",
  "uid": "vienna-os-governance",
  "version": 1
}
