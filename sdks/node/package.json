{
  "name": "@vienna-os/client",
  "version": "0.1.0",
  "description": "Vienna OS — AI Governance Platform SDK for Node.js / TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "governance",
    "compliance",
    "vienna-os",
    "audit",
    "warrants"
  ],
  "author": "Vienna OS <sdk@regulator.ai>",
  "license": "MIT",
  "homepage": "https://regulator.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/risk-ai/regulator.ai",
    "directory": "sdks/node"
  },
  "bugs": {
    "url": "https://github.com/risk-ai/regulator.ai/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
