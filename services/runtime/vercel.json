{
  "version": 2,
  "buildCommand": "cd vienna-core/console/client && npm ci && npm run build",
  "outputDirectory": "vienna-core/console/client/dist",
  "installCommand": "echo 'Skipping root install'",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://vienna-os.fly.dev/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
