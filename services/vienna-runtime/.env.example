# Vienna Runtime Service Configuration

# Server
PORT=4001
NODE_ENV=development

# State Backend
VIENNA_STATE_BACKEND=memory
# Options: memory | sqlite | postgres

# Artifact Storage
VIENNA_ARTIFACT_BACKEND=filesystem
# Options: filesystem | s3 | vercel-blob

# Data Directory (for filesystem backend)
VIENNA_DATA_DIR=./data

# Database (if using postgres backend)
# DATABASE_URL=postgresql://user:pass@localhost:5432/vienna

# CORS (allowed origins for browser access)
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info
# Options: error | warn | info | debug
