# Vienna Runtime Service Configuration (Stage 6)

# Server
PORT=4001
NODE_ENV=development

# Database Backend (Stage 6 - Automatic Selection)
# -----------------------------------------------------------------------------
# Backend is selected automatically based on DATABASE_URL:
# - DATABASE_URL not set → SQLite (local development, zero-config)
# - DATABASE_URL set → Postgres (staging/production, Neon-compatible)
#
# Local Development (no DATABASE_URL needed):
#   SQLite file created at: ./data/vienna.db
#
# Staging/Production (set DATABASE_URL):
#   DATABASE_URL=postgresql://user:pass@ep-name.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# Leave DATABASE_URL commented out for local development.
# -----------------------------------------------------------------------------

# DATABASE_URL=postgresql://user:pass@localhost:5432/vienna

# Artifact Storage
ARTIFACT_STORAGE_TYPE=filesystem
# Options: filesystem | s3 | vercel-blob
# Default: filesystem (stores in ./data/artifacts/)

# Data Directory (for filesystem backends)
VIENNA_DATA_DIR=./data

# CORS (allowed origins for browser access)
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info
# Options: error | warn | info | debug
