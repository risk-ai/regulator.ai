# ============================================================================
# Vienna Console Caddy Reverse Proxy Configuration
# ============================================================================
# Replace <DOMAIN> with actual domain before deployment
# Installation: sudo cp Caddyfile /etc/caddy/Caddyfile
# Validate: sudo caddy validate --config /etc/caddy/Caddyfile
# Reload: sudo systemctl reload caddy

app.<DOMAIN> {
    # Root directory for frontend static files
    root * /opt/vienna/console/dist
    
    # API reverse proxy (backend)
    handle /api/* {
        reverse_proxy 127.0.0.1:3100 {
            # Health check
            health_uri /health
            health_interval 30s
            health_timeout 5s
            
            # Headers
            header_up Host {upstream_hostport}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    
    # Health check endpoint (backend)
    handle /health {
        reverse_proxy 127.0.0.1:3100
    }
    
    # Frontend SPA (single-page app routing)
    handle {
        # Try files first, fallback to index.html for client-side routing
        try_files {path} /index.html
        file_server
    }
    
    # Security headers
    header {
        # HSTS (1 year)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        
        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"
        
        # Prevent clickjacking
        X-Frame-Options "DENY"
        
        # XSS protection
        X-XSS-Protection "1; mode=block"
        
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        
        # Content Security Policy (adjust as needed)
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.anthropic.com"
    }
    
    # Gzip compression
    encode gzip zstd
    
    # Logging
    log {
        output file /var/log/caddy/vienna-access.log
        format json
        level INFO
    }
    
    # Error logging
    log {
        output file /var/log/caddy/vienna-error.log
        format json
        level ERROR
    }
}

# Optional: Redirect www to non-www
www.app.<DOMAIN> {
    redir https://app.<DOMAIN>{uri} permanent
}
