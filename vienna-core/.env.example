# Vienna OS Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED - Application will not start without these
# ============================================================================

# Operator password for dashboard access
VIENNA_OPERATOR_PASSWORD=your-secure-password-here

# Session encryption secret (generate with: openssl rand -hex 32)
VIENNA_SESSION_SECRET=generate-with-openssl-rand-hex-32

# ============================================================================
# OPTIONAL - AI Provider Configuration
# ============================================================================

# Anthropic API key for AI features
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Anthropic backup key (for rate limit failover)
ANTHROPIC_API_KEY_BACKUP=sk-ant-your-backup-key-here

# Ollama local endpoint (if using local models)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name
OLLAMA_MODEL=qwen2.5:0.5b

# ============================================================================
# OPTIONAL - Server Configuration
# ============================================================================

# Node environment
NODE_ENV=development

# Server port
PORT=3100

# Server host (use 0.0.0.0 for Docker/production)
HOST=0.0.0.0

# ============================================================================
# OPTIONAL - Database Configuration
# ============================================================================

# SQLite database path
DATABASE_PATH=/app/runtime/prod/state/state.db

# ============================================================================
# OPTIONAL - Security Configuration
# ============================================================================

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5174,http://localhost:3000

# ============================================================================
# OPTIONAL - Workspace Configuration
# ============================================================================

# OpenClaw workspace path (if integrating with OpenClaw)
OPENCLAW_WORKSPACE=/tmp/openclaw-workspace

# ============================================================================
# OPTIONAL - Logging Configuration
# ============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Log format (json or text)
LOG_FORMAT=text

# ============================================================================
# OPTIONAL - Feature Flags
# ============================================================================

# Enable anomaly detection
ENABLE_ANOMALY_DETECTION=true

# Enable agent proposals
ENABLE_AGENT_PROPOSALS=true

# Enable approval workflow
ENABLE_APPROVAL_WORKFLOW=true

# ============================================================================
# OPTIONAL - Performance Configuration
# ============================================================================

# Maximum concurrent executions
MAX_CONCURRENT_EXECUTIONS=10

# Execution timeout (milliseconds)
EXECUTION_TIMEOUT_MS=300000

# Queue processing interval (milliseconds)
QUEUE_POLL_INTERVAL_MS=5000

# ============================================================================
# OPTIONAL - Monitoring Configuration
# ============================================================================

# Sentry DSN (for error tracking)
SENTRY_DSN=

# Datadog API key (for APM)
DATADOG_API_KEY=

# ============================================================================
# Development Only
# ============================================================================

# Skip authentication in development (NEVER use in production!)
# SKIP_AUTH=true

# Enable debug logging
# DEBUG=vienna:*
