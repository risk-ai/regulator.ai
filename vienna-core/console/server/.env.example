# Vienna Console Server Configuration

# ============================================================================
# Required Configuration
# ============================================================================

# Operator password for authentication (REQUIRED)
VIENNA_OPERATOR_PASSWORD=your_secure_password_here

# ============================================================================
# Optional Configuration
# ============================================================================

# Operator name (default: vienna)
VIENNA_OPERATOR_NAME=vienna

# Session secret for signing cookies (generate with: openssl rand -hex 32)
# If not set, a random secret is generated (sessions won't persist across restarts)
VIENNA_SESSION_SECRET=

# Session TTL in milliseconds (default: 86400000 = 24 hours)
VIENNA_SESSION_TTL=86400000

# Server configuration
PORT=3100
HOST=localhost
NODE_ENV=development

# OpenClaw workspace path (default: ~/.openclaw/workspace)
OPENCLAW_WORKSPACE=

# CORS origin (for development)
CORS_ORIGIN=
