# ============================================================================
# Vienna Console Production Configuration Template
# ============================================================================
# Copy to .env.production and fill in actual values before deployment
# Never commit .env.production to version control

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=production
PORT=3100
HOST=127.0.0.1                    # Bind to localhost (behind reverse proxy)

# ============================================================================
# Public URLs (set after domain acquired)
# ============================================================================
PUBLIC_URL=https://app.<DOMAIN>
API_BASE_URL=https://app.<DOMAIN>/api/v1

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGIN=https://app.<DOMAIN>   # Single origin (reverse proxy handles routing)
CORS_CREDENTIALS=true

# ============================================================================
# Cookie Configuration
# ============================================================================
COOKIE_DOMAIN=                      # Empty = same-origin (recommended)
COOKIE_SECURE=true                  # HTTPS only (required in production)
COOKIE_SAMESITE=lax                 # CSRF mitigation

# ============================================================================
# Session Configuration
# ============================================================================
# REQUIRED: Generate with: openssl rand -hex 32
VIENNA_SESSION_SECRET=<GENERATE_STRONG_SECRET>
VIENNA_SESSION_TTL=86400000         # 24 hours (milliseconds)

# ============================================================================
# Auth Configuration
# ============================================================================
# REQUIRED: Rotate from dev default before launch
VIENNA_OPERATOR_PASSWORD=<STRONG_PASSWORD>
VIENNA_OPERATOR_NAME=vienna

# ============================================================================
# Provider Configuration
# ============================================================================
# REQUIRED: Production API key (not dev key)
ANTHROPIC_API_KEY=<PRODUCTION_KEY>
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_TIMEOUT_MS=30000

# Local fallback provider
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_TIMEOUT_MS=10000

# ============================================================================
# OpenClaw Gateway
# ============================================================================
OPENCLAW_GATEWAY_URL=http://localhost:18789

# ============================================================================
# Workspace
# ============================================================================
OPENCLAW_WORKSPACE=/opt/vienna/workspace

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info                      # debug | info | warn | error
LOG_FORMAT=json                     # json | pretty

# ============================================================================
# Performance
# ============================================================================
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT_MS=30000

# ============================================================================
# Health Check
# ============================================================================
HEALTH_CHECK_INTERVAL_MS=30000
