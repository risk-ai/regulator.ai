{
  "name": "vienna-os",
  "version": "2.0.0",
  "description": "Vienna OS - Governed AI Operating System",
  "main": "index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev:server": "cd console/server && npm run dev",
    "dev:client": "cd console/client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "cd console/server && npm run build",
    "build:client": "cd console/client && npm run build",
    "build": "npm run build:server && npm run build:client",
    "start": "cd console/server && npm start",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:phase6": "jest tests/phase6",
    "test:phase15": "node test-phase-15-end-to-end.js",
    "test:phase16": "node test-phase-16-integration.js",
    "test:phase17": "node test-phase-17-validation.js",
    "lint": "eslint lib/",
    "validate": "node scripts/validate-schemas.js",
    "postinstall": "cd console/server && npm install && cd ../client && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "ajv": "^8.12.0",
    "better-sqlite3": "^12.6.2",
    "nanoid": "^3.3.7",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@types/node": "^25.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "governance",
    "warrant",
    "vienna",
    "execution-control",
    "ai-operating-system"
  ],
  "author": "Vienna Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaxAnderson-code/vienna-os.git"
  }
}
